{
  "name": "@assistant-ui/devtools-extension",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build-extension.mts",
    "dev": "NODE_ENV=development tsx scripts/build-extension.mts --watch",
    "deps:check": "npx taze major -f -x",
    "deps:update": "npx taze major -f -w && pnpm install",
    "deps:update:no-install": "npx taze major -f -w -x"
  },
  "dependencies": {
    "@assistant-ui/react-devtools": "workspace:*",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.0",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
