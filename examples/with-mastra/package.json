{
  "name": "with-mastra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,mastra -c cyan,yellow \"next dev\" \"tsx watch src/server.ts\"",
    "build": "pnpm build:web && pnpm build:server",
    "build:web": "next build",
    "build:server": "tsc6 -p tsconfig.server.json",
    "start": "concurrently -k -n web,mastra \"next start\" \"node dist/server.js\""
  },
  "dependencies": {
    "@assistant-ui/react": "workspace:*",
    "@assistant-ui/react-ai-sdk": "workspace:*",
    "@assistant-ui/react-markdown": "workspace:*",
    "@assistant-ui/react-mastra": "workspace:*",
    "@assistant-ui/ui": "workspace:*",
    "@hono/node-server": "2.0.10",
    "@mastra/ai-sdk": "^1.6.2",
    "@mastra/client-js": "^1.32.0",
    "@mastra/core": "^1.51.0",
    "@mastra/hono": "^1.5.7",
    "@mastra/libsql": "^1.16.0",
    "@mastra/memory": "^1.23.0",
    "ai": "^7.0.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.30",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@assistant-ui/next": "workspace:*",
    "@assistant-ui/x-buildutils": "workspace:*",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.23.1",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}
