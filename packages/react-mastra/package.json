{
  "name": "@assistant-ui/react-mastra",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/useMastraMemory.d.ts",
      "default": "./dist/useMastraMemory.js"
    },
    "./workflows": {
      "types": "./dist/useMastraWorkflows.d.ts",
      "default": "./dist/useMastraWorkflows.js"
    },
    "./health": {
      "types": "./dist/health.d.ts",
      "default": "./dist/health.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "aui-build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/core": "^0.2.18",
    "assistant-stream": "^0.3.23",
    "uuid": "^14.0.1"
  },
  "peerDependencies": {
    "@mastra/core": "^1.45.0",
    "@types/react": "*",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@mastra/core": {
      "optional": true
    },
    "@types/react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@assistant-ui/x-buildutils": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "homepage": "https://www.assistant-ui.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/assistant-ui/assistant-ui.git",
    "directory": "packages/react-mastra"
  },
  "bugs": {
    "url": "https://github.com/assistant-ui/assistant-ui/issues"
  }
}
